{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=pdf_processing;Username=postgres;Password=postgres"
  },
  "Minio": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSsl": false,
    "Bucket": "pdfs"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "User": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Exchange": "pdf.processing",
    "DlxExchange": "pdf.processing.dlx",
    "Queue": "pdf.process",
    "DlqQueue": "pdf.process.dlq",
    "RoutingKey": "pdf.process.requested",
    "DlqRoutingKey": "pdf.process.dead",
    "PrefetchCount": 10
  },
  "PdfProcessing": {
    "MaxAttempts": 5,
    "MaxFileSizeMb": 50
  },
  "OutboxPublishing": {
    "MaxRetries": 20,
    "BaseRetrySeconds": 5,
    "MaxRetryDelaySeconds": 900
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  }
}
